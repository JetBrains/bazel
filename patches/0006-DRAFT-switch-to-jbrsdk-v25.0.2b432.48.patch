diff --git a/src/minimize_jdk.sh b/src/minimize_jdk.sh
index 32a2f274fd..7d37a45c20 100755
--- a/src/minimize_jdk.sh
+++ b/src/minimize_jdk.sh
@@ -123,6 +123,16 @@ else
   tar xf "$tooljdk" --no-same-owner --strip-components=1 -C tool_jdk
   mkdir target_jdk
   tar xf "$fulljdk" --no-same-owner --strip-components=1 -C target_jdk
+  # JBR macOS ships the JDK under Contents/Home; flatten that into tool_jdk/target_jdk.
+  if [[ "$UNAME" =~ darwin ]]; then
+    for dir in tool_jdk target_jdk; do
+      if [ -d "$dir/Contents/Home" ]; then
+        mv "$dir/Contents/Home" "${dir}.home.$$"
+        rm -rf "$dir"
+        mv "${dir}.home.$$" "$dir"
+      fi
+    done
+  fi
   cd target_jdk
   # If the full JDK doesn't ship with jmods (e.g. JEP 493), use the separately
   # provided jmods archive.
