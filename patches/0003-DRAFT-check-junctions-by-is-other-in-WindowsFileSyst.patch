From 9edd31b3f1a0fe0db3144f8c39c666653d723908 Mon Sep 17 00:00:00 2001
From: Mikhail Filippov <mikhail@filippov.me>
Date: Tue, 21 Apr 2026 19:53:03 +0400
Subject: [PATCH 3/5] DRAFT check junctions by is other in
 WindowsFileSystem#stat

---
 .../google/devtools/build/lib/windows/WindowsFileSystem.java   | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/main/java/com/google/devtools/build/lib/windows/WindowsFileSystem.java b/src/main/java/com/google/devtools/build/lib/windows/WindowsFileSystem.java
index 7c98485b17..e0e077a7c6 100644
--- a/src/main/java/com/google/devtools/build/lib/windows/WindowsFileSystem.java
+++ b/src/main/java/com/google/devtools/build/lib/windows/WindowsFileSystem.java
@@ -172,7 +172,8 @@ public class WindowsFileSystem extends JavaIoFileSystem {
           @Override
           public boolean isSymbolicLink() {
             if (isSymbolicLink == null) {
-              isSymbolicLink = !followSymlinks && fileIsSymbolicLink(file);
+              // BasicFileAttributes#isOther is true iff FILE_ATTRIBUTE_DEVICE or FILE_ATTRIBUTE_REPARSE_POINT, assume no devices under output user root
+              isSymbolicLink = !followSymlinks && (attributes.isSymbolicLink() || attributes.isOther()) && fileIsSymbolicLink(file);
             }
             return isSymbolicLink;
           }
